    "server.js"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@reneza/ats-core": "^0.3.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@reneza/ats-adapter-ticktick": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "@reneza/ats-adapter-ticktick": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renezander030/agentic-task-system.git",
    "directory": "packages/mcp"
  },
