{
  "name": "@reneza/ats-core",
  "version": "0.4.0",
  "description": "Adapter-agnostic core for Agentic Task System \u2014 retrieval (RRF parallel fan-out), corpus cache, usage logging, conformance kit, adapter interface",
  "type": "module",
  "main": "index.js",
  "types": "./index.d.ts",
  "files": [
    "*.js",
    "*.d.ts"
  ],
  "exports": {
    ".": { "types": "./index.d.ts", "default": "./index.js" },
    "./retrieval": { "types": "./retrieval.d.ts", "default": "./retrieval.js" },
    "./corpus-cache": { "types": "./corpus-cache.d.ts", "default": "./corpus-cache.js" },
    "./usage-log": { "types": "./usage-log.d.ts", "default": "./usage-log.js" },
    "./conformance": { "types": "./conformance.d.ts", "default": "./conformance.js" },
    "./adapter-interface": { "types": "./adapter-interface.d.ts", "default": "./adapter-interface.js" }
  },
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "node ../../scripts/check-no-pii.mjs --self"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renezander030/agentic-task-system.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/renezander030/agentic-task-system#readme",
  "bugs": {
    "url": "https://github.com/renezander030/agentic-task-system/issues"
  },
  "author": "Ren\u00e9 Zander",
  "keywords": [
    "rrf",
    "reciprocal-rank-fusion",
    "hybrid-search",
    "parallel-retrieval",
    "semantic-search",
    "retrieval",
    "qdrant",
    "nomic-embed",
    "agent-retrieval",
    "corpus-cache",
    "rag-evaluation",
    "embedding-fallback",
    "agentic",
    "agent-memory",
    "agent-context",
    "context-engineering",
    "claude",
    "mcp"
  ]
}