{
  "name": "agentic-task-system",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Your task manager is the best agent memory you're not using. Agent-native context layer over your existing task app, with hybrid retrieval (RRF) and pluggable storage adapters.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "eslint packages",
    "check:pii": "node scripts/check-no-pii.mjs",
    "check:publish": "node scripts/check-no-pii.mjs --npm",
    "test:fast": "node --test --test-timeout=10000 packages/core/test/*.test.js packages/mcp/test/*.test.js packages/cli/test/*.test.js packages/adapter-obsidian/test/*.test.js",
    "test": "npm run lint && npm run check:pii && npm run test:fast"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renezander030/agentic-task-system.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7"
  }
}
